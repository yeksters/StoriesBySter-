<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stories by Ster</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0D0B09;--bg2:#161310;--surface:#1E1A16;
  --cream:#F5F0E8;--muted:#6B6058;
  --gold:#C9A96E;--rust:#B85C38;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--cream);font-family:'DM Sans',sans-serif;font-weight:300;overflow-x:hidden}

nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.5rem 4rem;
  background:rgba(13,11,9,0.94);backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(201,169,110,0.07);
}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:400;letter-spacing:0.06em;color:var(--cream);text-decoration:none}
.nav-logo span{font-style:italic;color:var(--gold)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.25s}
.nav-links a:hover{color:var(--gold)}

.hero{position:relative;min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:80px}
.hero-text{display:flex;flex-direction:column;justify-content:center;padding:6rem 4rem 6rem 5rem}
.hero-tag{font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.75rem}
.hero-tag::before{content:'';display:block;width:2rem;height:1px;background:var(--gold)}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3.5rem,6vw,5.5rem);font-weight:300;line-height:1.0;color:var(--cream);margin-bottom:0.1em}
.hero-by{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;font-size:clamp(3rem,5.5vw,5rem);color:var(--gold);line-height:1.0;display:block;margin-bottom:2rem}
.hero-desc{font-size:0.88rem;line-height:1.9;color:rgba(245,240,232,0.6);max-width:360px;margin-bottom:2.5rem}
.hero-cta{display:inline-flex;align-items:center;gap:0.75rem;font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--cream);text-decoration:none;border-bottom:1px solid rgba(245,240,232,0.3);padding-bottom:0.2rem;width:fit-content;transition:color 0.25s,border-color 0.25s}
.hero-cta:hover{color:var(--gold);border-color:var(--gold)}
.hero-visual{position:relative;overflow:hidden;background:var(--surface)}
.hero-visual img{width:100%;height:100%;object-fit:cover;display:block;object-position:center top}
.hero-visual-label{position:absolute;bottom:1.5rem;left:1.5rem;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.8rem;color:rgba(245,240,232,0.7);text-shadow:0 1px 6px rgba(13,11,9,0.6)}

.divider{display:flex;align-items:center;gap:1.5rem;padding:4rem 5rem;color:var(--muted);font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:linear-gradient(to right,transparent,rgba(201,169,110,0.2),transparent)}

.section{padding:0 4rem 6rem}
.section-header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:3rem}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;color:var(--cream)}
.section-title em{font-style:italic;color:var(--gold)}
.section-count{font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted)}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.7rem}
.pf{position:relative;overflow:hidden;cursor:pointer;background:var(--surface);aspect-ratio:3/2}
.pf.tall{aspect-ratio:2/3}
.pf.wide{grid-column:span 2;aspect-ratio:16/9}
.pf img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.6s ease;filter:brightness(0.88)}
.pf:hover img{transform:scale(1.06);filter:brightness(1)}
.pf-hover{position:absolute;inset:0;background:rgba(13,11,9,0.35);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s}
.pf-hover span{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:var(--cream);letter-spacing:0.1em}
.pf:hover .pf-hover{opacity:1}

.about{display:grid;grid-template-columns:1fr 1fr;background:var(--bg2);margin:0 4rem 6rem;border:1px solid rgba(201,169,110,0.06)}
.about-img{position:relative;overflow:hidden;min-height:480px}
.about-img img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;filter:brightness(0.85)}
.about-text{padding:5rem;display:flex;flex-direction:column;justify-content:center}
.about-tag{font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.75rem}
.about-tag::before{content:'';display:block;width:2rem;height:1px;background:var(--gold)}
.about-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,2.8rem);font-weight:300;color:var(--cream);line-height:1.15;margin-bottom:1.5rem}
.about-title em{font-style:italic;color:var(--gold)}
.about-rule{width:40px;height:1px;background:rgba(201,169,110,0.3);margin-bottom:1.8rem}
.about-body{font-size:0.88rem;line-height:2;color:rgba(245,240,232,0.55);margin-bottom:2.5rem}
.about-link{display:inline-flex;align-items:center;gap:0.75rem;font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:1px solid rgba(201,169,110,0.25);padding-bottom:0.2rem;width:fit-content;transition:border-color 0.25s}
.about-link:hover{border-color:var(--gold)}

.contact{text-align:center;padding:5rem 4rem 9rem;background:var(--bg)}
.contact-tag{font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--rust);display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-bottom:1.5rem}
.contact-tag::before,.contact-tag::after{content:'';display:block;width:2rem;height:1px;background:var(--rust)}
.contact-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:300;line-height:1.1;margin-bottom:1rem;color:var(--cream)}
.contact-title em{font-style:italic;color:var(--rust)}
.contact-body{font-size:0.88rem;line-height:1.9;color:rgba(245,240,232,0.5);max-width:440px;margin:0 auto 2.5rem}
.contact-btn{display:inline-flex;align-items:center;gap:0.75rem;padding:0.9rem 2.5rem;border:1px solid rgba(201,169,110,0.3);color:var(--gold);font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;transition:background 0.25s,border-color 0.25s,color 0.25s}
.contact-btn:hover{background:var(--rust);border-color:var(--rust);color:var(--cream)}

footer{border-top:1px solid rgba(201,169,110,0.07);padding:2rem 5rem;display:flex;align-items:center;justify-content:space-between;background:var(--bg)}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--muted)}
.footer-logo span{font-style:italic;color:rgba(201,169,110,0.5)}
.footer-copy{font-size:0.7rem;color:var(--muted);letter-spacing:0.06em}

#lightbox{display:none;position:fixed;inset:0;z-index:9999;background:rgba(5,4,3,0.98);align-items:center;justify-content:center}
#lightbox.open{display:flex}
#lb-img{max-width:88vw;max-height:88vh;object-fit:contain;display:block}
#lb-close{position:fixed;top:1.5rem;right:2rem;background:none;border:none;color:#fff;font-size:2rem;cursor:pointer;opacity:0.4;line-height:1;transition:opacity 0.2s}
#lb-close:hover{opacity:1}
#lb-prev,#lb-next{position:fixed;top:50%;transform:translateY(-50%);background:none;border:none;color:#fff;font-size:3rem;cursor:pointer;padding:1.5rem;opacity:0.3;transition:opacity 0.2s;line-height:1}
#lb-prev{left:0}#lb-next{right:0}
#lb-prev:hover,#lb-next:hover{opacity:1}
#lb-count{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);font-size:0.65rem;letter-spacing:0.2em;color:rgba(255,255,255,0.25)}

.fade-up{opacity:0;transform:translateY(24px);animation:fu 0.9s cubic-bezier(0.25,0.46,0.45,0.94) forwards}
.d1{animation-delay:0.1s}.d2{animation-delay:0.25s}.d3{animation-delay:0.4s}.d4{animation-delay:0.55s}
@keyframes fu{to{opacity:1;transform:translateY(0)}}

@media(max-width:900px){
  nav{padding:1.2rem 1.5rem}
  .nav-links{display:none}
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero-text{padding:6rem 1.5rem 3rem}
  .hero-visual{min-height:60vw}
  .divider{padding:3rem 1.5rem}
  .section{padding-left:1.5rem;padding-right:1.5rem;padding-bottom:4rem}
  .grid{grid-template-columns:repeat(2,1fr)}
  .pf.wide{grid-column:span 2}
  .pf.tall{aspect-ratio:3/2}
  .about{grid-template-columns:1fr;margin:0 1.5rem 4rem}
  .about-img{min-height:300px}
  .about-text{padding:3rem 1.5rem}
  .contact{padding:3rem 1.5rem 5rem}
  footer{flex-direction:column;gap:0.5rem;text-align:center;padding:1.5rem}
}
@media(max-width:500px){
  .grid{grid-template-columns:1fr}
  .pf.wide,.pf.tall{grid-column:span 1;aspect-ratio:3/2}
}
</style>
</head>
<body>

<nav>
  <a href="#" class="nav-logo">Stories <span>by Ster</span></a>
  <ul class="nav-links">
    <li><a href="#">Home</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-text">
    <p class="hero-tag fade-up">Illustrations &amp; Stories</p>
    <h1 class="hero-title fade-up d1">Stories</h1>
    <span class="hero-by fade-up d2">by Ster</span>
    <p class="hero-desc fade-up d3">Where imagination meets ink — original illustrations and stories that breathe life into characters, worlds, and the quietly extraordinary.</p>
    <a href="#portfolio" class="hero-cta fade-up d4">View portfolio &rarr;</a>
  </div>
  <div class="hero-visual">
    <img src="https://raw.githubusercontent.com/yeksters/StoriesBySter-/main/Hero.jpeg" alt="Illustration by Y. Ster" />
    <div class="hero-visual-label">Original illustration — Y. Ster</div>
  </div>
</section>

<div class="divider">Portfolio</div>

<section class="section" id="portfolio">
  <div class="section-header">
    <h2 class="section-title">All <em>illustrations</em></h2>
    <span class="section-count">12 works</span>
  </div>
  <div class="grid" id="grid"></div>
</section>

<div class="about" id="about">
  <div class="about-img">
    <img src="https://raw.githubusercontent.com/yeksters/StoriesBySter-/main/Artist.jpeg" alt="Y. Ster" />
  </div>
  <div class="about-text">
    <p class="about-tag">About</p>
    <h2 class="about-title">The artist<br><em>behind the stories</em></h2>
    <div class="about-rule"></div>
    <p class="about-body">Y. Ster is an illustrator whose work lives at the intersection of myth, memory and the everyday. Rooted in Florence and shaped by a deep love of storytelling, each image carries its own inner world.<br><br>From ancient tragedy to the warmth of a Tuscan afternoon, the work spans worlds while remaining unmistakably human.</p>
    <a href="#contact" class="about-link">Get in touch &rarr;</a>
  </div>
</div>

<section class="contact" id="contact">
  <p class="contact-tag">Get in touch</p>
  <h2 class="contact-title">Let's create<br><em>something together</em></h2>
  <p class="contact-body">Whether you're looking for custom illustrations, collaborations, or just want to say hello — the door is always open.</p>
  <a href="mailto:ster.yek@gmail.com" class="contact-btn">Send a message &rarr;</a>
</section>

<footer>
  <span class="footer-logo">Stories <span>by Ster</span></span>
  <span class="footer-copy">&copy; 2026 Y. Ster &mdash; All rights reserved</span>
</footer>

<div id="lightbox" onclick="lbClose()">
  <button id="lb-close" onclick="lbClose()">&times;</button>
  <button id="lb-prev" onclick="event.stopPropagation();lbMove(-1)">&#8249;</button>
  <img id="lb-img" src="" alt="" onclick="event.stopPropagation()"/>
  <button id="lb-next" onclick="event.stopPropagation();lbMove(1)">&#8250;</button>
  <div id="lb-count"></div>
</div>

<script>
const imgs=[
  ["https://static.wixstatic.com/media/b09377_2c4b26a4490c439cb68a31330275ae19~mv2.jpg/v1/fill/w_807,h_1140,q_90,enc_avif,quality_auto/b09377_2c4b26a4490c439cb68a31330275ae19~mv2.jpg","tall"],
  ["https://static.wixstatic.com/media/b09377_3cf13e3a818743189d5a0f01ebc7fb10~mv2.png/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_3cf13e3a818743189d5a0f01ebc7fb10~mv2.png","wide"],
  ["https://static.wixstatic.com/media/b09377_0ae35ce2b43147979b7c032ed18764c4~mv2.jpg/v1/fill/w_807,h_1140,q_90,enc_avif,quality_auto/b09377_0ae35ce2b43147979b7c032ed18764c4~mv2.jpg","tall"],
  ["https://static.wixstatic.com/media/b09377_230fbbba827140469e0ae0b8ec44c841~mv2.jpg/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_230fbbba827140469e0ae0b8ec44c841~mv2.jpg","wide"],
  ["https://static.wixstatic.com/media/b09377_4e75818a7c184648af2f9abd3d2f90b5~mv2.jpg/v1/fill/w_807,h_1140,q_90,enc_avif,quality_auto/b09377_4e75818a7c184648af2f9abd3d2f90b5~mv2.jpg","tall"],
  ["https://static.wixstatic.com/media/b09377_1d19f4292aba4af1af59be56e3c7ff56~mv2.jpg/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_1d19f4292aba4af1af59be56e3c7ff56~mv2.jpg","wide"],
  ["https://static.wixstatic.com/media/b09377_c2b76b41f78340ad870b92e6062e3348~mv2.jpg/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_c2b76b41f78340ad870b92e6062e3348~mv2.jpg","wide"],
  ["https://static.wixstatic.com/media/b09377_0cec4e0b068b4f11bea24d62e73cc5b1~mv2.jpg/v1/fill/w_807,h_1140,q_90,enc_avif,quality_auto/b09377_0cec4e0b068b4f11bea24d62e73cc5b1~mv2.jpg","tall"],
  ["https://static.wixstatic.com/media/b09377_60c0d8abe46342138684a30b7683e82e~mv2.jpg/v1/fill/w_807,h_1140,q_90,enc_avif,quality_auto/b09377_60c0d8abe46342138684a30b7683e82e~mv2.jpg","tall"],
  ["https://static.wixstatic.com/media/b09377_4dce4a01fe83452b80328a5c0b1a7fbf~mv2.jpg/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_4dce4a01fe83452b80328a5c0b1a7fbf~mv2.jpg","wide"],
  ["https://static.wixstatic.com/media/b09377_366e28715c4a47e4a893958253a959f8~mv2.jpg/v1/fill/w_1614,h_1142,q_90,enc_avif,quality_auto/b09377_366e28715c4a47e4a893958253a959f8~mv2.jpg","wide"],
  ["https://static.wixstatic.com/media/b09377_6a543b39285c40f6bf6f82e10cac6817~mv2.jpg/v1/crop/x_0,y_5,w_2000,h_1276/fill/w_1890,h_1184,al_c,q_85,enc_avif,quality_auto/ciran.jpg","wide"]
];
const grid=document.getElementById('grid');
let cur=0;
imgs.forEach(([src,cls],i)=>{
  const d=document.createElement('div');
  d.className='pf'+(cls?' '+cls:'');
  d.innerHTML='<img src="'+src+'" alt="Illustration by Y. Ster" loading="lazy"><div class="pf-hover"><span>View</span></div>';
  d.addEventListener('click',()=>lbOpen(i));
  grid.appendChild(d);
});
function lbOpen(i){cur=i;document.getElementById('lb-img').src=imgs[i][0];document.getElementById('lb-count').textContent=(i+1)+' / '+imgs.length;document.getElementById('lightbox').classList.add('open');document.addEventListener('keydown',lbKey)}
function lbClose(){document.getElementById('lightbox').classList.remove('open');document.removeEventListener('keydown',lbKey)}
function lbMove(d){cur=(cur+d+imgs.length)%imgs.length;document.getElementById('lb-img').src=imgs[cur][0];document.getElementById('lb-count').textContent=(cur+1)+' / '+imgs.length}
function lbKey(e){if(e.key==='Escape')lbClose();if(e.key==='ArrowLeft')lbMove(-1);if(e.key==='ArrowRight')lbMove(1)}
</script>
</body>
</html>
